{
  "name": "Microsoft-Edge",
  "repo": "ghcr.io/ich777/microsoft-edge",
  "registry": "https://hub.docker.com/r/ich777/microsoft-edge/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --shm-size=2G",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/vnc.html?autoconnect=true",
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/edge.png",
  "project": "https://www.microsoft.com/edge",
  "support": "https://forums.unraid.net/topic/83786-support-ich777-application-dockers/",
  "description": "Microsoft Edge is a proprietary, cross-platform web browser created by Microsoft.",
  "category": "Productivity: Tools:Utilities",
  "paths": [
    {
      "name": "Data Dir",
      "host": "/mnt/cache/appdata/micrososft-edge/",
      "container": "/ms-edge",
      "mode": "rw",
      "description": "Data Path",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "noVNC WebGUI",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "TCP noVNC WebGUI",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "Extra Parameters",
      "key": "EXTRA_PARAMETERS",
      "value": null,
      "description": "If needed enter extra startup parameters here otherwise leave empty.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Microsoft Edge Version",
      "key": "MS_EDGE_V",
      "value": "latest",
      "description": "Set to 'latest' and the container will check on each container start if a newer version is available or set a static version (please note that only stable versions are supported by the container).",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "noVNC Resizing",
      "key": "NOVNC_RESIZE",
      "value": "remote",
      "description": "Valid options are 'off', 'scale', 'remote'.",
      "required": false,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": null,
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": null,
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "Custom Screen Width",
      "key": "CUSTOM_RES_W",
      "value": "1280",
      "description": "Minimum screen width 1024 pixels",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "Custom Screen Height",
      "key": "CUSTOM_RES_H",
      "value": "768",
      "description": "Minimum screen hight 768 pixels",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "Umask",
      "key": "UMASK",
      "value": "0000",
      "description": null,
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
