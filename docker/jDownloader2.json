{
  "name": "jDownloader2",
  "repo": "ghcr.io/ich777/jdownloader2",
  "registry": "https://hub.docker.com/r/ich777/jdownloader2/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/vnc.html?autoconnect=true",
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/jdownloader.png",
  "project": "http://jdownloader.org/",
  "support": "https://forums.unraid.net/topic/83786-support-ich777-application-dockers/",
  "description": "This Docker will download and install jDownloader2.\r\n\r\nJDownloader 2 is a free, open-source download management tool with a huge community of developers that makes downloading as easy and fast as it should be. Users can start, stop or pause downloads, set bandwith limitations, auto-extract archives and much more...\r\n\r\nUpdate Notice: Updates will be handled through jDownloader2 directly, simply click the 'Check for Updates' in the WebGUI.",
  "category": "MediaApp:Photos Productivity: Tools: Backup:",
  "paths": [
    {
      "name": "Data Dir",
      "host": "/mnt/cache/appdata/jdownloader2/",
      "container": "/jDownloader2",
      "mode": "rw",
      "description": "Container Path: /jDownloader2",
      "required": true,
      "display": "always",
      "default": null
    },
    {
      "name": "Download Path",
      "host": "/mnt/cache/jDownloader/",
      "container": "/mnt/jDownloader",
      "mode": "rw",
      "description": "Container Path: /mnt/jDownloader",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "WebGUI",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "Container Port: 8080",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "Connected Containers",
      "key": "CONNECTED_CONTAINERS",
      "value": null,
      "description": "If connected and routet through a VPN container compatible with the Connected Containers feature, allows the container to detect a restart from the VPN container and restart itself. The default value is: '127.0.0.1:27286' without quotes. If you don't want to use this feature leave this field empty.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Umask Value",
      "key": "UMASK",
      "value": "000",
      "description": "Container Variable: UMASK",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "Custom Screen Width",
      "key": "CUSTOM_RES_W",
      "value": "1024",
      "description": "Minimum screen width 1024 pixels",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "Custom Screen Height",
      "key": "CUSTOM_RES_H",
      "value": "768",
      "description": "Minimum screen hight 768 pixels",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
