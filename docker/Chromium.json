{
  "name": "Chromium",
  "repo": "ghcr.io/ich777/chrome",
  "registry": "https://hub.docker.com/r/ich777/chrome/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped --shm-size=2G",
  "post_parameters": null,
  "web_ui_url": "http://[IP]:[PORT:8080]/vnc.html?autoconnect=true",
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/chrome.png",
  "project": "https://www.google.com/chrome/",
  "support": "https://github.com/ich777/docker-chrome/issues",
  "description": "Chromium is a free and open-source software project developed by the Google-sponsored Chromium project.",
  "paths": [
    {
      "name": "Data Dir",
      "host": "/mnt/cache/appdata/chrome/",
      "container": "/chrome",
      "mode": "rw",
      "description": "Data Path",
      "required": true
    }
  ],
  "ports": [
    {
      "name": "noVNC WebGUI",
      "host": "8080",
      "container": "8080",
      "protocol": "tcp",
      "description": "TCP noVNC WebGUI",
      "required": true,
      "mask": false
    }
  ],
  "variables": [
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false
    },
    {
      "name": "Custom Screen Width",
      "key": "CUSTOM_RES_W",
      "value": "1280",
      "description": "Minimum screen width 1024 pixels",
      "required": true,
      "mask": false
    },
    {
      "name": "Custom Screen Height",
      "key": "CUSTOM_RES_H",
      "value": "768",
      "description": "Minimum screen hight 768 pixels",
      "required": true,
      "mask": false
    },
    {
      "name": "Umask",
      "key": "UMASK",
      "value": "000",
      "description": "Container Variable: UMASK",
      "required": true,
      "mask": false
    }
  ],
  "devices": [],
  "labels": []
}
