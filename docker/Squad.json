{
  "name": "Squad",
  "repo": "ghcr.io/ich777/steamcmd:squad",
  "registry": "https://hub.docker.com/r/ich777/steamcmd/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/squad.png",
  "project": "https://www.steampowered.com/",
  "support": "https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/",
  "description": "This Docker will download and install SteamCMD. It will also install Squad and run it.\r\n\r\nATTENTION: First Startup can take very long since it downloads the gameserver files!\r\n\r\nUpdate Notice: Simply restart the container if a newer version of the game is available.\r\n\r\nYou can also run multiple servers with only one SteamCMD directory!",
  "category": "GameServers:",
  "paths": [
    {
      "name": "SteamCMD",
      "host": "/mnt/cache/appdata/steamcmd",
      "container": "/serverdata/steamcmd",
      "mode": "rw",
      "description": "Container Path: /serverdata/steamcmd",
      "required": true,
      "display": "always",
      "default": null
    },
    {
      "name": "ServerFiles",
      "host": "/mnt/cache/appdata/squad",
      "container": "/serverdata/serverfiles",
      "mode": "rw",
      "description": "Container Path: /serverdata/serverfiles",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "UDP1 - Game Port 1",
      "host": "7787",
      "container": "7787",
      "protocol": "udp",
      "description": "UDP Gameport (if you need another port, please delete this entry and create a new UDP Port with the required port number, also don't forget to change the port number in the 'GAME_PARAMS')",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP2 - Game Port 2",
      "host": "7788",
      "container": "7788",
      "protocol": "udp",
      "description": "UDP Game Port +1",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP3 - Query Port 1",
      "host": "27165",
      "container": "27165",
      "protocol": "udp",
      "description": "UDP Query Port (if you need another port, please delete this entry and create a new UDP Port with the required port number, also don't forget to change the port number in the 'GAME_PARAMS')",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP4 - Query Port 2",
      "host": "27166",
      "container": "27166",
      "protocol": "udp",
      "description": "UDP Query Port +1",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "TCP1 - Query Port 2",
      "host": "27166",
      "container": "27166",
      "protocol": "tcp",
      "description": "Container Port: 27166",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "TCP2 - RCON Port",
      "host": "21114",
      "container": "21114",
      "protocol": "tcp",
      "description": "TCP RCON Port (not required)",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP5 - RCON Port:",
      "host": "21114",
      "container": "21114",
      "protocol": "udp",
      "description": "UDP RCON Port (not required)",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "GAME_ID",
      "key": "GAME_ID",
      "value": "403240",
      "description": "The GAME_ID that the container download at startup.\r\n(https://developer.valvesoftware.com/wiki/Dedicated_Servers_List)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "GAME_PARAMS",
      "key": "GAME_PARAMS",
      "value": "Port=7787 QueryPort=27165",
      "description": "Enter your start up commands for the server.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Validate Installation",
      "key": "VALIDATE",
      "value": null,
      "description": "Set the Variable to 'true' if you want to validate the installation otherwise leave it blank.",
      "required": false,
      "mask": false,
      "display": "always-hide",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
