{
  "name": "Hurtworld",
  "repo": "ghcr.io/ich777/steamcmd:hurtworld",
  "registry": "https://hub.docker.com/r/ich777/steamcmd/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/hurtworld.png",
  "project": "https://www.steampowered.com/",
  "support": "https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/",
  "description": "This Docker will download and install SteamCMD. It will also install Hurtworld and run it.\r\n\r\nATTENTION: First Startup can take very long since it downloads the gameserver files!\r\n\r\nUpdate Notice: Simply restart the container if a newer version of the game is available.\r\n\r\nYou can also run multiple servers with only one SteamCMD directory!",
  "category": "GameServers:",
  "paths": [
    {
      "name": "SteamCMD",
      "host": "/mnt/cache/appdata/steamcmd",
      "container": "/serverdata/steamcmd",
      "mode": "rw",
      "description": "Container Path: /serverdata/steamcmd",
      "required": true,
      "display": "always",
      "default": null
    },
    {
      "name": "ServerFiles",
      "host": "/mnt/cache/appdata/hurtworld",
      "container": "/serverdata/serverfiles",
      "mode": "rw",
      "description": "Container Path: /serverdata/serverfiles",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "UDP1 - Game Port",
      "host": "12871",
      "container": "12871",
      "protocol": "udp",
      "description": "UDP Gameport (if you need another port, please delete this entry and create a new UDP Port with the required port number, also don't forget to click an 'Show more settings ...' and change the port number)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP2 - Query Port",
      "host": "12881",
      "container": "12881",
      "protocol": "udp",
      "description": "UDP Queryport (if you need another port, please delete this entry and create a new UDP Port with the required port number, also don't forget to click an 'Show more settings ...' and change the port number)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "GAME_ID",
      "key": "GAME_ID",
      "value": "405100",
      "description": "The GAME_ID that the container download at startup.\r\n(https://developer.valvesoftware.com/wiki/Dedicated_Servers_List)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "EXTRA_GAME_PARAMS",
      "key": "GAME_PARAMS",
      "value": ";autosaveenabled 1;addadmin 76561197963117432",
      "description": "Enter your extra start up commands for the server starting with a ';' (without quotes e.g. ';afkkicktime 900;autosaveenabled 0). Don't forget to change the admin SteamID.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Validate Installation",
      "key": "VALIDATE",
      "value": null,
      "description": "Set the Variable to 'true' if you want to validate the installation otherwise leave it blank.",
      "required": false,
      "mask": false,
      "display": "always-hide",
      "default": null
    },
    {
      "name": "Server Name",
      "key": "SRV_NAME",
      "value": "Hurtworld Docker",
      "description": "Enter your servername.",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Maxplayers",
      "key": "SRV_MAXPLAYERS",
      "value": "50",
      "description": "Enter the maximum allowed players",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GAME_PORT",
      "key": "GAME_PORT",
      "value": "12871",
      "description": "Container Variable: GAME_PORT",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "QUERY_PORT",
      "key": "QUERY_PORT",
      "value": "12881",
      "description": "Container Variable: QUERY_PORT",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
