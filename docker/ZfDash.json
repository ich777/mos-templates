{
  "name": "ZfDash",
  "repo": "ghcr.io/ad4mts/zfdash:latest",
  "network": "bridge",
  "custom_ip": "",
  "default_shell": "",
  "privileged": false,
  "no_autoupdate": false,
  "extra_parameters": "--cap-add SYS_ADMIN",
  "post_parameters": "",
  "web_ui_url": "http://[ADDRESS]:[PORT:5001]",
  "icon": "https://raw.githubusercontent.com/ad4mts/zfdash/main/src/data/icons/zfs-gui.png",
  "project": "https://github.com/ad4mts/zfdash",
  "support": "https://github.com/ad4mts/zfdash/issues",
  "description": "ZfDash simplifies ZFS administration on Linux, macOS, and FreeBSD through intuitive graphical interfaces. Built with Python and featuring a secure daemon architecture, it provides comprehensive ZFS management capabilities without requiring command-line expertise.\nDefault Login::\nUsername: admin\nPassword: admin",
  "category": [ "Game Server" ],
  "paths": [
    {
      "name": "Config Directory",
      "mode": "",
      "host": "/mnt/cache/appdata/zfdash/config",
      "container": "/root/.config/ZfDash",
      "description": "Configuration Directory for ZfDash"
    },
    {
      "name": "Data directory",
      "mode": "",
      "host": "/mnt/cache/appdata/zfdash/data",
      "container": "/opt/zfdash/data",
      "description": "Data Directory for ZfDash"
    },
    {
      "name": "Host /etc directory",
      "mode": "ro",
      "host": "/etc",
      "container": "/host-etc",
      "description": "Mount for Host /etc directory"
    },
    {
      "name": "Mount Host device into the container (read only)",
      "mode": "ro",
      "host": "/dev",
      "container": "/dev",
      "description": "Mount for Host /dev directory"
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "5001",
      "container": "5001",
      "description": "WebUI Port for ZfDash"
    }
  ],
  "variables": [],
  "devices": [
    {
      "name": "Host Devices",
      "host": "/dev/zfs",
      "container": "/dev/zfs",
      "description": "Host mount for ZFS devices"
    }
  ],
  "labels": [],
  "gpus": []
}
