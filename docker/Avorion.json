{
  "name": "Avorion",
  "repo": "ghcr.io/ich777/steamcmd:avorion",
  "registry": "https://hub.docker.com/r/ich777/steamcmd/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/avorion.png",
  "project": "https://www.steampowered.com/",
  "support": "https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/",
  "description": "This Docker will download and install SteamCMD. It will also install Avorion and run it.\r\n\r\nATTENTION: First Startup can take very long since it downloads the gameserver files!\r\n\r\nUpdate Notice: Simply restart the container if a newer version of the game is available.\r\n\r\nYou can also run multiple servers with only one SteamCMD directory!",
  "category": "GameServers:",
  "paths": [
    {
      "name": "SteamCMD",
      "host": "/mnt/cache/appdata/steamcmd",
      "container": "/serverdata/steamcmd",
      "mode": "rw",
      "description": "Container Path: /serverdata/steamcmd",
      "required": true,
      "display": "always",
      "default": null
    },
    {
      "name": "ServerFiles",
      "host": "/mnt/cache/appdata/avorion",
      "container": "/serverdata/serverfiles",
      "mode": "rw",
      "description": "Container Path: /serverdata/serverfiles",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "Host Port 1",
      "host": "27000",
      "container": "27000",
      "protocol": "tcp",
      "description": "Container Port: 27000",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Host Port 2",
      "host": "27000",
      "container": "27000",
      "protocol": "udp",
      "description": "Container Port: 27000",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Host Port 3",
      "host": "27003",
      "container": "27003",
      "protocol": "udp",
      "description": "Container Port: 27003",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Host Port 4",
      "host": "27020",
      "container": "27020",
      "protocol": "udp",
      "description": "Container Port: 27020",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Host Port 5",
      "host": "27021",
      "container": "27021",
      "protocol": "udp",
      "description": "Container Port: 27021",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "GAME_ID",
      "key": "GAME_ID",
      "value": "565060",
      "description": "The GAME_ID that the container download at startup.\r\n(https://developer.valvesoftware.com/wiki/Dedicated_Servers_List)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Galaxy Name",
      "key": "GALAXY_NAME",
      "value": "AvorionDocker",
      "description": "Enter the Galaxy Name here (also the savepath will be the same as the Galaxy Name in the serverfiles folder, please use no spaces or special characters).",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "GAME_PARAMS",
      "key": "GAME_PARAMS",
      "value": null,
      "description": "Enter your start up commands for the server (for example the server admin: --admin [YOURsteamID64] e.g: '--admin 123456789123456789' without quotes).",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Validate Installation",
      "key": "VALIDATE",
      "value": null,
      "description": "Set the Variable to 'true' if you want to validate the installation otherwise leave it blank.",
      "required": false,
      "mask": false,
      "display": "always-hide",
      "default": null
    },
    {
      "name": "UMASK",
      "key": "UMASK",
      "value": "000",
      "description": "Container Variable: UMASK",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
