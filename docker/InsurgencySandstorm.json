{
  "name": "InsurgencySandstorm",
  "repo": "ghcr.io/ich777/steamcmd:insurgencysandstorm",
  "registry": "https://hub.docker.com/r/ich777/steamcmd/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/insurgencysandstorm.png",
  "project": "https://www.steampowered.com/",
  "support": "https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/",
  "description": "This Docker will download and install SteamCMD. It will also install Insurgency Sandstorm and run it.\r\n\r\nATTENTION: First Startup can take very long since it downloads the gameserver files!\r\n\r\nPASSWORD: The initial password is 'Docker', if you want to change or delete it look below at the section GAME_PARAMS.\r\n\r\nUpdate Notice: Simply restart the container if a newer version of the game is available.\r\n\r\nYou can also run multiple servers with only one SteamCMD directory!",
  "category": [ "Game Server" ],
  "paths": [
    {
      "name": "SteamCMD",
      "host": "/mnt/cache/appdata/steamcmd",
      "container": "/serverdata/steamcmd",
      "mode": "rw",
      "description": "Container Path: /serverdata/steamcmd",
      "required": true,
      "display": "always",
      "default": null
    },
    {
      "name": "ServerFiles",
      "host": "/mnt/cache/appdata/insurgencysandstorm",
      "container": "/serverdata/serverfiles",
      "mode": "rw",
      "description": "Container Path: /serverdata/serverfiles",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "UDP1 - Game Port",
      "host": "27102",
      "container": "27102",
      "protocol": "udp",
      "description": "Container Port: 27102",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "UDP2 - Query Port",
      "host": "27131",
      "container": "27131",
      "protocol": "udp",
      "description": "Container Port: 27131",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "GAME_ID",
      "key": "GAME_ID",
      "value": "581330",
      "description": "The GAME_ID that the container download at startup.\r\n(https://developer.valvesoftware.com/wiki/Dedicated_Servers_List)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "SERVER_NAME",
      "key": "SERVER_NAME",
      "value": "DockerServer",
      "description": "Container Variable: SERVER_NAME",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "GAME_PARAMS",
      "key": "GAME_PARAMS",
      "value": "Oilfield?Scenario=Scenario_Refinery_Push_Security?MaxPlayers=28?Password=Docker",
      "description": "Enter your start up commands for the server.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Validate Installation",
      "key": "VALIDATE",
      "value": null,
      "description": "Set the Variable to 'true' if you want to validate the installation otherwise leave it blank.",
      "required": false,
      "mask": false,
      "display": "always-hide",
      "default": null
    },
    {
      "name": "GAME_PORT",
      "key": "GAME_PORT",
      "value": "27102",
      "description": "Container Variable: GAME_PORT",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "QUERY_PORT",
      "key": "QUERY_PORT",
      "value": "27131",
      "description": "Container Variable: QUERY_PORT",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
