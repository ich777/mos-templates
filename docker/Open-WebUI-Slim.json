{
  "name": "Open-WebUI-Slim",
  "repo": "ghcr.io/open-webui/open-webui:slim",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "category": [ "AI", "Productivity" ],
  "description": "Open WebUI Slim is a lightweight, self-hosted web interface for interacting with LLMs, offering a streamlined ChatGPT-like experience without the overhead of bundled inference engines. Connect it to your existing Ollama instance or any OpenAI-compatible API to chat with your models through a clean, responsive UI.",
  "web_ui_url": "http://[ADDRESS]:[PORT:8080]/",
  "support": "https://github.com/open-webui/open-webui/issues",
  "icon": "https://raw.githubusercontent.com/open-webui/open-webui/main/static/favicon.png",
  "paths": [
    {
      "name": "Data",
      "host": "/mnt/cache/appdata/open-webui-slim",
      "container": "/app/backend/data",
      "description": "Main data path"
    }
  ],
  "ports": [
    {
      "name": "WebUI",
      "protocol": "tcp",
      "host": "8080",
      "container": "8080",
      "description": "WebUI Port"
    }
  ],
  "variables": [],
  "devices": [],
  "labels": [],
  "gpus": []
}