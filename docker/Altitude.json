{
  "name": "Altitude",
  "repo": "ghcr.io/ich777/altitude",
  "registry": "https://hub.docker.com/r/ich777/altitude/",
  "network": "bridge",
  "custom_ip": null,
  "default_shell": "bash",
  "privileged": false,
  "extra_parameters": "--restart=unless-stopped",
  "post_parameters": null,
  "web_ui_url": null,
  "icon": "https://raw.githubusercontent.com/ich777/docker-templates/master/ich777/images/altitude.png",
  "project": "https://www.steampowered.com/",
  "support": "https://forums.unraid.net/topic/79530-support-ich777-gameserver-dockers/",
  "description": "This Docker will download and install Altitude and run it.\r\n\r\nDefault Servername: Docker Altitude Server | Default Password: Docker | Default Admin Password: adminDocker\r\n\r\nATTENTION: First Startup can take very long since it downloads the gameserver files!\r\n\r\nUpdate Notice: Simply restart the container if a newer version of the game is available.",
  "category": [ "Game Server" ],
  "paths": [
    {
      "name": "ServerFiles",
      "host": "/mnt/cache/appdata/altitude",
      "container": "/altitude",
      "mode": "rw",
      "description": "Container Path: /altitude",
      "required": true,
      "display": "always",
      "default": null
    }
  ],
  "ports": [
    {
      "name": "UDP - Server Port",
      "host": "27276",
      "container": "27276",
      "protocol": "udp",
      "description": "UDP Game Port (if you need another port, please delete this entry and create a new UDP Port with the required port number, don't forget to change it also in your launcher_config.xml)",
      "required": true,
      "mask": false,
      "display": "always",
      "default": null
    }
  ],
  "variables": [
    {
      "name": "GAME_PARAMS",
      "key": "GAME_PARAMS",
      "value": null,
      "description": "Enter your start up commands for the server.",
      "required": false,
      "mask": false,
      "display": "always",
      "default": null
    },
    {
      "name": "Download URL",
      "key": "DL_URL",
      "value": "http://installer.altitudegame.com/0.0.1/altitude.sh",
      "description": "Don't change unless you know what you are doing.",
      "required": true,
      "mask": false,
      "display": "advanced",
      "default": null
    },
    {
      "name": "UID",
      "key": "UID",
      "value": "500",
      "description": "Container Variable: UID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    },
    {
      "name": "GID",
      "key": "GID",
      "value": "500",
      "description": "Container Variable: GID",
      "required": true,
      "mask": false,
      "display": "advanced-hide",
      "default": null
    }
  ],
  "devices": [],
  "labels": []
}
